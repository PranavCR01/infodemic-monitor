# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres
DATABASE_URL_SYNC=postgresql://user:password@host:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_STORAGE_BUCKET=videos
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Inference
INFERENCE_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Whisper
WHISPER_PROVIDER=faster_whisper
WHISPER_MODEL_SIZE=base

# Storage
STORAGE_BACKEND=supabase

# Celery
CELERY_CONCURRENCY=1

# Pipeline limits (usually left at defaults)
MAX_INPUT_CHARS=128000
PUBMED_RESULTS_PER_CLAIM=2

# Migrations
RUN_MIGRATIONS=true

# Auth
REQUIRE_AUTH=false
ALLOWED_ORIGINS=http://localhost:3000
